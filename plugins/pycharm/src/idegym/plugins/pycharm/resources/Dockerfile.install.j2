# Install PyCharm {{ version }}
# https://www.jetbrains.com/pycharm/download/other.html
# Requires 2026.1.1+; older versions are not supported.
USER root
RUN set -eux; \
    apt-get update -qq; \
    apt-get install -y --no-install-recommends \
        ca-certificates curl unzip xvfb procps socat xdotool \
        libxtst6 libxrender1 libxi6 libfreetype6 fontconfig; \
    apt-get clean; \
    rm -rf /var/lib/apt/lists/*

ENV PYCHARM_VERSION="{{ version }}"
ENV PYCHARM_DIR="/opt/pycharm"
ENV IDE_CONFIG_PATH="{{ config_dir }}"
RUN set -eux; \
    arch=$(dpkg --print-architecture); \
    case "$arch" in \
        amd64) suffix="" ;; \
        arm64) suffix="-aarch64" ;; \
        *) echo "Unsupported arch: $arch" >&2; exit 1 ;; \
    esac; \
    archive="pycharm-{{ version }}${suffix}.tar.gz"; \
    curl -fsSL "https://download.jetbrains.com/python/${archive}" -o /tmp/pycharm.tar.gz; \
    curl -fsSL "https://download.jetbrains.com/python/${archive}.sha256" -o /tmp/pycharm.sha256; \
    expected=$(cut -d' ' -f1 /tmp/pycharm.sha256); \
    echo "$expected  /tmp/pycharm.tar.gz" | sha256sum -c -; \
    mkdir -p ${PYCHARM_DIR}; \
    tar -xzf /tmp/pycharm.tar.gz -C ${PYCHARM_DIR} --strip-components=1; \
    rm /tmp/pycharm.tar.gz /tmp/pycharm.sha256

ENV JAVA_HOME="${PYCHARM_DIR}/jbr"
ENV PATH="${JAVA_HOME}/bin:${PYCHARM_DIR}/bin:${PATH}"
ENV DISPLAY=":99"

# Configure PyCharm for headless/CI use.
# These settings apply to every JVM invocation including inspect.sh:
#   -Didea.config.path   avoids XDG detection failures in containers
#   -Dide.trust.all.projects=true  suppresses the interactive "Trust Project?" dialog
#   the remaining flags suppress first-run/consent/update dialogs and tune the JVM for containers
RUN set -eux; \
    mkdir -p "{{ config_dir }}/options"; \
    mkdir -p /root/.local/share/JetBrains/consentOptions; \
    printf '%s\n' 'rsch.send.usage.stat:1.1:1:1700000000000' \
        > /root/.local/share/JetBrains/consentOptions/accepted; \
    printf '%s\n' \
        'com.intellij.marketplace' \
        'com.intellij.settingsSync' \
        'com.jetbrains.codeWithMe' \
        > "{{ config_dir }}/disabled_plugins.txt"; \
    for f in "${PYCHARM_DIR}/bin/pycharm64.vmoptions" "${PYCHARM_DIR}/bin/pycharm.vmoptions"; do \
        [ -f "$f" ] && printf '\n-Didea.config.path={{ config_dir }}\n-Dide.trust.all.projects=true\n-Djb.privacy.policy.text=<!--999.999-->\n-Dide.firstStartup=false\n-Dide.no.platform.update=true\n-Djb.consents.confirmation.enabled=false\n-Dide.show.tips.on.startup.default.value=false\n-Dide.browser.jcef.enabled=false\n-Dsun.net.client.defaultConnectTimeout=5000\n-Dsun.net.client.defaultReadTimeout=10000\n-XX:-UsePerfData\n-XX:+PerfDisableSharedMem\n-XX:-UseLargePages\n-Xshare:off\n-XX:+UseContainerSupport\n-XX:ErrorFile=/tmp/jvm-crash.log\n' >> "$f" || true; \
    done
