# ── OpenEnv image tags ────────────────────────────────────────────────────────
# Tags of the Docker images loaded into Minikube (see README.md Step 2).
ECHO_ENV_IMAGE_TAG=echo-env:local
TBENCH2_IMAGE_TAG=tbench2-env:local

# ── IdeGYM orchestrator ───────────────────────────────────────────────────────
# URL of the running orchestrator.
# Default points to the local Minikube deployment (no auth required).
# For a remote/production orchestrator, uncomment and fill in the values below.
IDEGYM_ORCHESTRATOR_URL=http://idegym.test

# IDEGYM_AUTH_USERNAME=admin
# IDEGYM_AUTH_PASSWORD=your-password
